*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'DM Sans',sans-serif;background:var(--off);color:var(--g1);overflow-x:hidden;}
header{position:sticky;top:0;z-index:300;background:rgba(10,46,28,.97);display:flex;align-items:center;justify-content:space-between;padding:0 48px;height:58px;}
.logo{font-family:'Syne',sans-serif;font-weight:800;font-size:18px;color:#fff;}
.logo b{color:var(--g4);}
.chips{display:flex;gap:6px;}
.chip{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);color:rgba(255,255,255,.65);padding:5px 13px;border-radius:20px;font-size:12px;cursor:pointer;transition:.2s;}
.chip:hover,.chip.on{background:var(--g3);border-color:var(--g3);color:#fff;}
.hero{max-width:1200px;margin:0 auto;padding:60px 48px 44px;display:grid;grid-template-columns:1fr auto;gap:48px;align-items:center;}
.eye{font-size:11px;font-weight:600;letter-spacing:.2em;text-transform:uppercase;color:var(--g3);margin-bottom:12px;display:flex;align-items:center;gap:8px;}
.eye::before{content:'';width:24px;height:2px;background:var(--g3);}
h1{font-family:'Syne',sans-serif;font-size:56px;font-weight:800;line-height:1;color:var(--g1);margin-bottom:14px;}
h1 em{font-style:normal;background:linear-gradient(135deg,var(--g2),var(--g4));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.sub{font-size:15px;line-height:1.7;color:var(--muted);max-width:440px;}
.stats{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.stat{background:#fff;border:1px solid var(--bdr);border-radius:14px;padding:18px 22px;text-align:center;position:relative;overflow:hidden;}
.stat::after{content:'';position:absolute;bottom:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--g2),var(--g4));}
.sn{font-family:'Syne',sans-serif;font-size:34px;font-weight:800;color:var(--g2);line-height:1;}
.sl2{font-size:11px;color:var(--muted);margin-top:3px;}
.bnr{max-width:1200px;margin:0 auto 40px;padding:0 48px;}
.bnr-in{background:var(--g1);border-radius:18px;padding:28px 40px;display:flex;align-items:center;justify-content:space-between;gap:28px;}
.bnr-in h2{font-family:'Syne',sans-serif;font-size:19px;font-weight:700;color:#fff;margin-bottom:5px;}
.bnr-in p{font-size:13px;color:rgba(255,255,255,.5);line-height:1.5;max-width:420px;}
.bpills{display:flex;gap:7px;flex-wrap:wrap;flex-shrink:0;}
.bpill{background:rgba(255,255,255,.09);border:1px solid rgba(255,255,255,.15);color:rgba(255,255,255,.85);padding:6px 13px;border-radius:18px;font-size:12px;}
.fbar{max-width:1200px;margin:0 auto 28px;padding:0 48px;display:flex;gap:7px;align-items:center;}
.fl{font-size:11px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.1em;margin-right:4px;}
.fb{background:#fff;border:1px solid var(--bdr);color:var(--muted);padding:6px 14px;border-radius:18px;font-size:12px;cursor:pointer;transition:.2s;font-family:'DM Sans',sans-serif;}
.fb:hover{border-color:var(--g3);color:var(--g3);}
.fb.on{background:var(--g2);border-color:var(--g2);color:#fff;}
.wrap{max-width:1200px;margin:0 auto;padding:0 48px 72px;}
.grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;}
.cw.leader{grid-column:1/-1;}
.cw.leader .card{flex-direction:row;height:220px;}
.cw.leader .photo{width:200px;min-width:200px;border-radius:16px 0 0 16px;}
.cw.leader .cbody{padding:24px 28px;justify-content:center;}
.cw.leader .cname{font-size:22px;}
.cw.leader .rbadge{background:var(--g2);color:#fff;}
.cw.hidden{display:none;}
.cw{cursor:pointer;}
.card{background:#fff;border:1px solid var(--bdr);border-radius:16px;overflow:hidden;display:flex;flex-direction:column;height:360px;transition:transform .28s,box-shadow .28s;position:relative;}
.card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--g2),var(--g4));z-index:2;}
.card:hover{transform:translateY(-6px);box-shadow:0 20px 48px rgba(10,46,28,.14);}
.photo{width:100%;height:200px;flex-shrink:0;background-size:cover;background-repeat:no-repeat;position:relative;}
.fade{position:absolute;inset:0;background:linear-gradient(to bottom,transparent 55%,rgba(10,46,28,.2));}
.crown{position:absolute;top:10px;left:10px;background:rgba(10,46,28,.85);color:#fff;font-size:10px;font-weight:700;padding:4px 10px;border-radius:8px;z-index:3;}
.cbody{padding:14px 16px;display:flex;flex-direction:column;gap:5px;flex:1;}
.rbadge{display:inline-flex;align-items:center;gap:4px;background:var(--g6);color:var(--g2);font-size:10px;font-weight:700;letter-spacing:.05em;text-transform:uppercase;padding:3px 9px;border-radius:6px;width:fit-content;}
.cname{font-family:'Syne',sans-serif;font-size:15px;font-weight:700;color:var(--g1);}
.cnum{font-size:11px;color:var(--muted);}
.ctags{display:flex;flex-wrap:wrap;gap:4px;margin-top:auto;}
.tag{background:var(--g6);color:var(--g3);font-size:10px;padding:3px 7px;border-radius:5px;}
.ccta{text-align:center;padding:9px;font-size:11px;color:rgba(46,125,82,.45);border-top:1px solid var(--bdr);background:rgba(234,244,238,.4);}
.ov{position:fixed;inset:0;z-index:500;background:rgba(5,18,10,0);pointer-events:none;transition:background .35s;}
.ov.on{background:rgba(5,18,10,.78);pointer-events:all;}
.slide{position:fixed;inset:0;z-index:501;display:flex;transform:translateY(100%);transition:transform .45s cubic-bezier(.22,1,.36,1);pointer-events:none;}
.slide.on{transform:translateY(0);pointer-events:all;}
.sl-img{width:40%;flex-shrink:0;background-size:cover;background-repeat:no-repeat;position:relative;}
.sl-fade{position:absolute;inset:0;background:linear-gradient(to right,transparent 50%,rgba(10,46,28,.97)),linear-gradient(to bottom,rgba(10,46,28,.2) 0%,transparent 30%,transparent 70%,rgba(10,46,28,.4));}
.sl-badge{position:absolute;top:24px;left:24px;background:rgba(10,46,28,.85);color:#fff;font-size:12px;font-weight:700;padding:7px 16px;border-radius:10px;}
.sl-body{flex:1;background:var(--g1);overflow-y:auto;padding:44px 44px 80px;}
.sl-body::-webkit-scrollbar{width:3px;}
.sl-body::-webkit-scrollbar-thumb{background:rgba(255,255,255,.15);border-radius:2px;}
.sl-x{position:absolute;top:20px;right:20px;width:36px;height:36px;border-radius:50%;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.15);color:rgba(255,255,255,.7);font-size:16px;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:.2s;}
.sl-x:hover{background:rgba(255,255,255,.2);color:#fff;}
.sl-role{font-size:10px;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--g4);margin-bottom:8px;}
.sl-name{font-family:'Syne',sans-serif;font-size:36px;font-weight:800;color:#fff;line-height:1.05;margin-bottom:4px;}
.sl-num{font-size:12px;color:rgba(255,255,255,.3);margin-bottom:20px;}
.sl-div{width:32px;height:2px;background:linear-gradient(90deg,var(--g3),var(--g4));margin-bottom:18px;border-radius:1px;}
.sl-bio{font-size:14px;line-height:1.75;color:rgba(255,255,255,.65);margin-bottom:24px;}
.ig{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:18px;}
.ib{background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.08);border-radius:12px;padding:14px 16px;}
.ib-l{font-size:9px;font-weight:700;letter-spacing:.13em;text-transform:uppercase;color:rgba(255,255,255,.28);margin-bottom:4px;}
