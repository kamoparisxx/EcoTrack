var cur=-1;
// Set card photos
document.querySelectorAll('.cw').forEach(function(w){
  var i=parseInt(w.dataset.i);
  w.querySelector('.photo').style.backgroundImage="url('"+IMGS[i]+"')";
  w.addEventListener('click',function(){openS(i);});
});
// Build nav dots
T.forEach(function(_,i){
  var d=document.createElement('div');
  d.className='dot';
  d.addEventListener('click',function(){openS(i);});
  document.getElementById('dotsEl').appendChild(d);
});
document.getElementById('pa').addEventListener('click',function(){go(-1);});
document.getElementById('na').addEventListener('click',function(){go(1);});
document.getElementById('slX').addEventListener('click',closeS);
document.getElementById('ov').addEventListener('click',closeS);
function openS(i){
  cur=i; var p=T[i];
  document.getElementById('slImg').style.backgroundImage="url('"+IMGS[i]+"')";
  document.getElementById('slBadge').textContent=(p.leader?'👑 Leader · ':'')+p.emoji+' '+p.role;
  document.getElementById('slRole').textContent=p.role.toUpperCase();
  document.getElementById('slName').textContent=p.name;
  document.getElementById('slNum').textContent=p.num;
  document.getElementById('slBio').textContent=p.bio;
  document.getElementById('slDeg').textContent=p.degree;
  document.getElementById('slStr').textContent=p.strengths;
  document.getElementById('slCar').textContent=p.career;
  document.getElementById('slPer').innerHTML='<strong>'+p.personality+'</strong><br><small style="color:rgba(255,255,255,.5)">'+p.personality_exp+'</small>';
  document.getElementById('slBel').innerHTML='<strong>'+p.belbin+'</strong><br><small style="color:rgba(255,255,255,.5)">'+p.belbin_exp+'</small>';
  document.getElementById('slTags').innerHTML=p.tags.map(function(t){return '<span class="sl-tag">'+t+'</span>';}).join('');
  document.getElementById('slide').classList.add('on');
  document.getElementById('ov').classList.add('on');
  document.getElementById('nav').classList.add('on');
  document.getElementById('dotsEl').classList.add('on');
  document.body.style.overflow='hidden';
  document.getElementById('slBody').scrollTop=0;
  updUI();
}
function closeS(){
  document.getElementById('slide').classList.remove('on');
  document.getElementById('ov').classList.remove('on');
  document.getElementById('nav').classList.remove('on');
  document.getElementById('dotsEl').classList.remove('on');
  document.body.style.overflow='';
  cur=-1;
}
function go(d){var n=cur+d;if(n>=0&&n<T.length)openS(n);}
function updUI(){
  document.querySelectorAll('.dot').forEach(function(d,i){d.classList.toggle('on',i===cur);});
  document.getElementById('pa').classList.toggle('off',cur<=0);
  document.getElementById('na').classList.toggle('off',cur>=T.length-1);
}
document.addEventListener('keydown',function(e){
  if(cur<0)return;
  if(e.key==='ArrowRight'||e.key==='ArrowDown')go(1);
  if(e.key==='ArrowLeft'||e.key==='ArrowUp')go(-1);
  if(e.key==='Escape')closeS();
});
function filt(g,btn){
  document.querySelectorAll('.chip,.fb').forEach(function(b){b.classList.remove('on');});
  document.querySelectorAll('.chip,.fb').forEach(function(b){
    if(b.getAttribute('onclick')&&b.getAttribute('onclick').indexOf("'"+g+"'")>-1)b.classList.add('on');
  });
  document.querySelectorAll('.cw').forEach(function(w){
    if(w.classList.contains('leader'))return;
    (g==='all'||w.dataset.g===g)?w.classList.remove('hidden'):w.classList.add('hidden');
  });
}
// Counters
function countUp(id,target,sfx){
  var el=document.getElementById(id),n=0,step=Math.ceil(target/25);
  el.textContent='0'+(sfx||'');
  var t=setInterval(function(){n=Math.min(n+step,target);el.textContent=n+(sfx||'');if(n>=target)clearInterval(t);},50);
}
setTimeout(function(){countUp('c1',9);countUp('c2',8);countUp('c3',60);countUp('c4',30,'%');},400);
