.sl-tl{font-size:9px;font-weight:700;letter-spacing:.13em;text-transform:uppercase;color:rgba(255,255,255,.28);margin-bottom:8px;}
.sl-tags{display:flex;flex-wrap:wrap;gap:5px;}
.sl-tag{background:rgba(76,175,125,.15);border:1px solid rgba(76,175,125,.25);color:var(--g5);font-size:11px;padding:4px 11px;border-radius:7px;}
.nav{position:fixed;bottom:24px;right:44px;z-index:502;display:none;gap:9px;}
.nav.on{display:flex;}
.arr{width:44px;height:44px;border-radius:50%;background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.2);color:#fff;font-size:17px;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:.2s;}
.arr:hover{background:var(--g3);}
.arr.off{opacity:.25;pointer-events:none;}
.dots{position:fixed;bottom:32px;left:50%;transform:translateX(-50%);z-index:502;display:none;gap:6px;}
.dots.on{display:flex;}
.dot{width:6px;height:6px;border-radius:50%;background:rgba(255,255,255,.25);cursor:pointer;transition:.2s;}
.dot.on{background:#fff;transform:scale(1.4);}
footer{background:var(--g1);padding:24px 48px;display:flex;align-items:center;justify-content:space-between;}
.fr{font-size:12px;color:rgba(255,255,255,.35);text-align:right;line-height:1.65;}
@media(max-width:900px){header,.hero,.bnr,.fbar,.wrap,footer{padding-left:20px;padding-right:20px;}.hero{grid-template-columns:1fr;padding-top:44px;}h1{font-size:40px;}.grid{grid-template-columns:1fr 1fr;}.cw.leader .card{flex-direction:column;height:auto;}.cw.leader .photo{width:100%;height:200px;border-radius:16px 16px 0 0;}.slide{flex-direction:column;}.sl-img{width:100%;height:40vh;}.sl-body{padding:28px 22px 80px;}.ig{grid-template-columns:1fr;}.sl-name{font-size:26px;}}
